{
  "name": "credilix-acessos",
  "version": "1.0.0",
  "description": "Pilot backend for Credilix access/content management",
  "main": "dist/server.js",
  "scripts": {
    "build:web": "npm run build --prefix web",
    "bundle:ftp": "node scripts/prepare-ftp-bundle.mjs",
    "start:prod": "node dist/server.js",
    "dev": "cross-env PORT=5050 APP_BASE_URL=http://127.0.0.1:5050 tsx watch src/server.ts",
    "dev:ui": "npm run build:web && cross-env PORT=5050 APP_BASE_URL=http://127.0.0.1:5050 tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && npm run build:web && cross-env PORT=5050 APP_BASE_URL=http://127.0.0.1:5050 node dist/server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/walkup-tec/acesos-redlix.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/walkup-tec/acesos-redlix/issues"
  },
  "homepage": "https://github.com/walkup-tec/acesos-redlix#readme",
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.2",
    "@types/nodemailer": "^8.0.0",
    "cross-env": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
